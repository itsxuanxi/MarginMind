# ============================================================
# MarginMind — Environment Variables
# ------------------------------------------------------------
# EVERYTHING IS OPTIONAL. With no keys set, the app runs in
# fully-featured DEMO MODE backed by realistic mock data.
# Add real keys to light up live auth / billing / AI / DB.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated Clerk user IDs (or emails) that may access /admin.
ADMIN_EMAILS=zhang2543723434@gmail.com

# --- Clerk (Authentication) -------------------------------
# If these are unset, the app uses a built-in demo session.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# --- Supabase (Database) ----------------------------------
# If unset, mock data is served from lib/mock-data.ts
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (AI Profit Agent) -----------------------------
# If unset, the agent returns high-quality mock recommendations.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Stripe (Billing) -------------------------------------
# If unset, billing runs in demo mode (instant simulated upgrade, no charges).
# Use TEST keys first (https://dashboard.stripe.com/test/apikeys).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring CAD price IDs — create two monthly prices in Stripe:
#   Founding Customer: $9.99 CAD / month   → STRIPE_FOUNDING_PRICE_ID
#   Pro:               $29.99 CAD / month  → STRIPE_PRO_PRICE_ID
STRIPE_FOUNDING_PRICE_ID=
STRIPE_PRO_PRICE_ID=
